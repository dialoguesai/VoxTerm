<?xml version="1.0" encoding="utf-8"?>
<!-- Merged into the app manifest: on-device transcription needs the microphone. No INTERNET
     permission is added here — the on-device path makes no network calls. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
</manifest>
