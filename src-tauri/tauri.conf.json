{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxTerm",
  "version": "0.1.0",
  "identifier": "site.nubs.voxterm",
  "build": {
    "frontendDist": "../mobile-pair",
    "devUrl": "http://127.0.0.1:8740"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoxTerm",
        "width": 420,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug",
      "minSdkVersion": 24
    }
  }
}
