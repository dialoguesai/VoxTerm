{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxTerm",
  "version": "0.1.0",
  "identifier": "site.nubs.voxterm",
  "build": {
    "frontendDist": "../mobile-pair"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoxTerm",
        "width": 1100,
        "height": 720,
        "minWidth": 420,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' http://localhost:* ipc: http://ipc.localhost; font-src 'self'; manifest-src 'self'; worker-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug",
      "minSdkVersion": 24
    },
    "iOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
