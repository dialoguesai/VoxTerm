# Generated by Cargo
# will have compiled files and executables
/target/
/gen/schemas
# Android build artifacts + machine-specific files
/gen/android/.gradle
/gen/android/app/build
/gen/android/app/.cxx
/gen/android/build
/gen/android/local.properties
/gen/android/.idea
# iOS (generated on a Mac by `cargo tauri ios init`)
/gen/apple/Externals
/gen/apple/build
/gen/apple/Pods
/gen/apple/.tauri
/gen/apple/*.xcworkspace
/gen/apple/project.yml
