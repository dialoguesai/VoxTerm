# EVM private key for the Safe owner (Gnosis chain). Generate fresh:
#   node -e "console.log(require('viem/accounts').generatePrivateKey())"
# This is the single point of compromise — keep it out of git, rotate by
# spinning up a new Safe + namespace if it ever leaks.
PRIVATE_KEY=

# Pimlico API key for sponsoring Safe txns on Gnosis. Free dev tier is fine
# for ~150 txns/month. Get one at https://dashboard.pimlico.io/
PIMLICO_API_KEY=

# Pinata JWT for IPFS pinning. Free tier covers tiny markdown files easily.
# Get one at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=
PINATA_GATEWAY=gateway.pinata.cloud

# Namespace name for the Fileverse Agent's Safe + creds. All transcripts land
# under one Safe; the namespace just labels the on-disk creds file.
NAMESPACE=voxterm-shape-rotator

# Bearer token clients must send in `Authorization: Bearer <token>`.
# Generate with: openssl rand -hex 32
VOXTERM_UPLOAD_TOKEN=

# HTTP bind config. Default is localhost-only; override if running behind
# a reverse proxy (Caddy / nginx / Cloudflare).
HOST=127.0.0.1
PORT=8000

# SQLite mirror path for fast list/fetch (the SDK has no list endpoint).
DB_PATH=./sidecar.db

# Where Agent SDK persists per-namespace creds. The README says to gitignore.
CREDS_DIR=./creds
