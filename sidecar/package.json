{
  "name": "voxterm-fileverse-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Thin HTTP sidecar that wraps @fileverse/agents so VoxTerm clients can post transcripts to a Fileverse-backed collector with on-chain provenance.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test test/"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fileverse/agents": "^2.0.1",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "viem": "^2.21.0"
  }
}
